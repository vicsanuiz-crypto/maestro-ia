# === IA ===
GOOGLE_API_KEY=AIza...

# Modelo de IA que usa el Maestro (chat + briefing).
# Opciones validas: pro-2-5 | flash-2-5 | flash-2-0
# Por defecto (si no esta seteado): flash-2-5
MAESTRO_MODEL=flash-2-5

# === Base de datos ===
# LOCAL (desarrollo): deja TURSO_* vacias y usa un archivo SQLite local.
DATABASE_URL=./maestro.db

# PRODUCCION (Vercel): rellena estas dos con los datos de tu base Turso.
# Si TURSO_DATABASE_URL esta presente, se ignora DATABASE_URL.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Seguridad ===
# Secreto que permite al cron de Vercel saltarse el limite anti-abuso de
# /api/ingest y /api/briefing. Genera uno largo y aleatorio. Ponlo igual
# aqui (o en .env.local) y en las variables de entorno de Vercel.
CRON_SECRET=
